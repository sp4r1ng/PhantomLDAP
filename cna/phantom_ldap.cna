# phantom_ldap.cna
#
# PhantomLDAP — Main Cobalt Strike Aggressor Script
#
# Registers all PhantomLDAP BOF commands in Cobalt Strike's command parser.
# Load this script via: Cobalt Strike → Script Manager → Load
#
# Dependencies: helpers.cna, menus.cna (auto-sourced by this script)
#
# Version: 1.0.0
# Author:  PhantomLDAP Project
#

# ============================================================================
# Bootstrap — source companion scripts
# ============================================================================

local('%script_dir');
%script_dir = script_resource("");

source(script_resource("helpers.cna"));
source(script_resource("menus.cna"));

# ============================================================================
# Helper: resolve the BOF directory path
# ============================================================================

sub phantom_bof_path {
    local('$bof');
    $bof = script_resource("../build/" . $1 . ".o");
    if (!-exists $bof) {
        # Fallback: look in same dir as cna/
        $bof = script_resource($1 . ".o");
    }
    return $bof;
}

# ============================================================================
# Helper: execute a BOF on a set of beacons with packed args
# ============================================================================

sub phantom_exec_bof {
    local('$bid $module $args @bids');
    ($bid, $module, $args) = @_;
    local('$bof_path');
    $bof_path = phantom_bof_path($module);

    if (!-exists $bof_path) {
        berror($bid, "[PhantomLDAP] BOF not found: $bof_path\nRun 'make' to compile first.");
        return;
    }

    beacon_execute_bof($bid, $bof_path, $args);
}

# ============================================================================
# bof_enum_admins — Enumerate adminCount=1 accounts
# ============================================================================

beacon_command_register(
    "bof_enum_admins",
    "Enumerate AdminSDHolder-protected accounts (adminCount=1)",
    "Usage: bof_enum_admins [dc_hostname]\n\n" .
    "Enumerates all user accounts protected by AdminSDHolder (adminCount=1).\n" .
    "Includes UAC analysis, password age, delegation flags, and SID output.\n\n" .
    "Arguments:\n" .
    "  dc_hostname  (optional) Target DC FQDN. Auto-discovers if omitted.\n\n" .
    "Examples:\n" .
    "  bof_enum_admins\n" .
    "  bof_enum_admins dc01.corp.local"
);

alias bof_enum_admins {
    local('$bid $dc $args');
    $bid = $1;
    $dc  = $2 ? $2 : "";

    $args = bof_pack($bid, "Z", $dc);
    phantom_exec_bof($bid, "enum_admins", $args);
}

