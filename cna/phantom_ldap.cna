# ============================================================================
# bof_enum_acl — Full DACL binary analysis on a target object
# ============================================================================

beacon_command_register(
    "bof_enum_acl",
    "Parse and analyze DACL of an AD object (full binary ACE decoding)",
    "Usage: bof_enum_acl <distinguishedName> [dc_hostname]\n\n" .
    "Retrieves the nTSecurityDescriptor attribute of the target object\n" .
    "and fully parses all ACEs. Identifies DCSync rights, WriteDACL,\n" .
    "WriteOwner, ForceChangePassword, RBCD write, and other abusable ACEs.\n\n" .
    "Arguments:\n" .
    "  distinguishedName  Full DN of the target object (required)\n" .
    "  dc_hostname        (optional) DC to query\n\n" .
    "Examples:\n" .
    "  bof_enum_acl \"CN=Domain Admins,CN=Users,DC=corp,DC=local\"\n" .
    "  bof_enum_acl \"DC=corp,DC=local\" dc01.corp.local"
);

alias bof_enum_acl {
    local('$bid $dn $dc $args');
    $bid = $1;
    $dn  = $2 ? $2 : "";
    $dc  = $3 ? $3 : "";

    if ($dn eq "") {
        berror($bid, "Usage: bof_enum_acl <distinguishedName> [dc_hostname]");
        return;
    }

    $args = bof_pack($bid, "ZZ", $dn, $dc);
    phantom_exec_bof($bid, "enum_acl", $args);
}

# ============================================================================
# bof_ldap_query — Custom LDAP query
# ============================================================================

beacon_command_register(
    "bof_ldap_query",
    "Execute a custom LDAP filter and display results",
    "Usage: bof_ldap_query <filter> [attrs] [dc_hostname] [scope] [base_dn]\n\n" .
    "Executes an arbitrary LDAP filter and returns results. Useful for\n" .
    "targeted queries or validating filters before running full modules.\n\n" .
    "Arguments:\n" .
    "  filter       LDAP filter string (required)\n" .
    "  attrs        Comma-separated attribute list (optional, default: common attrs)\n" .
    "  dc_hostname  DC FQDN (optional)\n" .
    "  scope        0=BASE, 1=ONELEVEL, 2=SUBTREE (default: 2)\n" .
    "  base_dn      Custom search base (optional)\n\n" .
    "Examples:\n" .
    "  bof_ldap_query \"(&(objectClass=computer)(operatingSystem=*2003*))\"\n" .
    "  bof_ldap_query \"(sAMAccountName=john)\" \"mail,pwdLastSet,memberOf\"\n" .
    "  bof_ldap_query \"(objectClass=*)\" \"\" dc01.corp.local 0 \"DC=corp,DC=local\""
);

alias bof_ldap_query {
    local('$bid $filter $attrs $dc $scope $base $args');
    $bid    = $1;
    $filter = $2 ? $2 : "";
    $attrs  = $3 ? $3 : "";
    $dc     = $4 ? $4 : "";
    $scope  = $5 ? short($5) : 2s;
    $base   = $6 ? $6 : "";

    if ($filter eq "") {
        berror($bid, "Usage: bof_ldap_query <filter> [attrs] [dc] [scope] [base_dn]");
        return;
    }

    $args = bof_pack($bid, "ZZZsZ", $filter, $attrs, $dc, $scope, $base);
    phantom_exec_bof($bid, "ldap_query", $args);
}

# ============================================================================
# Startup Banner
# ============================================================================

on ready {
    println("\n[PhantomLDAP] v1.0.0 loaded — BOF directory: " . script_resource("../build/"));
    println("[PhantomLDAP] Commands: bof_enum_admins | bof_enum_spn | bof_enum_asrep");
    println("[PhantomLDAP]          bof_enum_computers | bof_enum_trusts | bof_enum_gpo");
    println("[PhantomLDAP]          bof_enum_acl | bof_ldap_query");
    println("[PhantomLDAP] Use 'help bof_<command>' for detailed usage.\n");
}
